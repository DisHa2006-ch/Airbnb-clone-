
<% layout("/layout/boilerplate") -%>

<div class="row row-cols-lg-3 row-cols-md-3 row-cols-sm-1 mt-3">
<% for (let Listing of allListing) { %>
 <% if(category) {%>
  <a href="/listing/<%= Listing._id%>" class="card_overlay" >
    <div class="card col listing-card" >
      <img src="<%= Listing.image.url %>" class="card-img-top" alt="listing-image" style="height: 20rem;">
      
      <div class="card-body">
        <p class="card-text">
          <b><%= Listing.title %></b>
          <br>
          &#8377;<%= Listing. price%>/night
          <i class="tax-info">&nbsp; &nbsp;+18% GST</i>
        </p>
      </div>
    </div>
  </a>
  
    <% } %>
    <% } %>
</div>